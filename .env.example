# ─────────────────────────────────────────────────────────────
# Stagelight environment example
# ─────────────────────────────────────────────────────────────
# This app uses Spotify's Authorization Code flow with PKCE, which
# runs entirely in the browser. In PKCE there is NO client secret —
# the Client ID is public and is entered directly in the app's UI.
#
# So for the current client-only setup you do NOT need a .env file
# at all. This file exists only as a template for the OPTIONAL
# serverless token-exchange on the roadmap.
#
# ⚠ Never put a Spotify Client SECRET in a public/static deployment.
#    A secret only belongs in a server-side function, never the browser.

# Public — safe to expose. Optional: only if you later want to
# pre-fill the Client ID instead of typing it in the UI.
SPOTIFY_CLIENT_ID=your_public_client_id_here

# The exact URL where the page is served (origin + path).
# Must match a Redirect URI registered in your Spotify app.
SPOTIFY_REDIRECT_URI=https://your-user.github.io/your-repo/

# ── Server-only (DO NOT use in the static build) ──
# Required only if you build the optional serverless token exchange.
# SPOTIFY_CLIENT_SECRET=keep_this_on_the_server_only
